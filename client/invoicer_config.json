    { "name": "LinkedInParser", "module": "js/parser/linkedin_parser.js" },
    { "name": "GmailParser", "module": "js/parser/gmail_parser.js" },
    { "name": "XParser", "module": "js/parser/x_parser.js" }
  ],
  "render": {
    "provider": "pdf",
    "outputDir": "Downloads/Invoices",
    "fileName": ""
  }
}


